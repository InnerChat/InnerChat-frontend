# ── API 서버 ──────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080
VITE_WORKSPACE_ID=1

# ── WebSocket / STOMP ─────────────────────────────────────
# SockJS 엔드포인트 (WebSocketMessageBrokerConfig: /ws)
VITE_WS_URL=http://localhost:8080/api/v1/ws

# 클라이언트 → 서버 발행 prefix (/app)
VITE_STOMP_APP_PREFIX=/app

# 서버 → 클라이언트 구독 prefix
VITE_STOMP_TOPIC_PREFIX=/topic
VITE_STOMP_QUEUE_PREFIX=/queue

# 개인(1:1) 메시지 prefix
VITE_STOMP_USER_PREFIX=/user
